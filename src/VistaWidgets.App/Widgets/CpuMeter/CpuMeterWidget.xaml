<UserControl x:Class="VistaWidgets.App.Widgets.CpuMeter.CpuMeterWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cpu="clr-namespace:VistaWidgets.App.Widgets.CpuMeter"
             Width="170"
             Height="128"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             ToolTip="{Binding DebugTooltip}">
    <Grid Background="Transparent">
        <cpu:GaugeControl Width="78"
                          Height="78"
                          Margin="85,4,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="RAM"
                          Value="{Binding MemoryUsage}"
                          Panel.ZIndex="0">
            <cpu:GaugeControl.Effect>
                <DropShadowEffect BlurRadius="11"
                                  ShadowDepth="3"
                                  Direction="315"
                                  Opacity="0.55"
                                  Color="#000000" />
            </cpu:GaugeControl.Effect>
        </cpu:GaugeControl>

        <Ellipse Width="114"
                 Height="114"
                 Margin="10,14,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="#35000000"
                 Panel.ZIndex="1">
            <Ellipse.Effect>
                <BlurEffect Radius="7" />
            </Ellipse.Effect>
        </Ellipse>

        <cpu:GaugeControl Width="108"
                          Height="108"
                          Margin="8,16,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="CPU"
                          Value="{Binding CpuUsage}"
                          Panel.ZIndex="2">
            <cpu:GaugeControl.Effect>
                <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="4"
                                  Direction="315"
                                  Opacity="0.62"
                                  Color="#000000" />
            </cpu:GaugeControl.Effect>
        </cpu:GaugeControl>
    </Grid>
</UserControl>
