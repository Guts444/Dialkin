<UserControl x:Class="VistaWidgets.App.Widgets.CpuMeter.CpuMeterWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cpu="clr-namespace:VistaWidgets.App.Widgets.CpuMeter"
             Width="196"
             Height="152"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             ToolTip="{Binding DebugTooltip}">
    <Grid Background="Transparent">
        <Path Fill="#30000000"
              IsHitTestVisible="False"
              Panel.ZIndex="0">
            <Path.Data>
                <GeometryGroup FillRule="Nonzero">
                    <EllipseGeometry Center="65,83"
                                     RadiusX="54"
                                     RadiusY="51" />
                    <EllipseGeometry Center="139,50"
                                     RadiusX="39"
                                     RadiusY="36" />
                </GeometryGroup>
            </Path.Data>
            <Path.Effect>
                <BlurEffect Radius="2.75" />
            </Path.Effect>
        </Path>

        <cpu:GaugeControl Width="80"
                          Height="80"
                          Margin="96,4,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="RAM"
                          Value="{Binding MemoryUsage}"
                          Panel.ZIndex="2" />

        <cpu:GaugeControl Width="112"
                          Height="112"
                          Margin="6,21,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="CPU"
                          Value="{Binding CpuUsage}"
                          Panel.ZIndex="3" />
    </Grid>
</UserControl>
