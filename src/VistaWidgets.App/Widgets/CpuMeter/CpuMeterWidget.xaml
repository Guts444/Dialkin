<UserControl x:Class="VistaWidgets.App.Widgets.CpuMeter.CpuMeterWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cpu="clr-namespace:VistaWidgets.App.Widgets.CpuMeter"
             Width="170"
             Height="110"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             ToolTip="{Binding DebugTooltip}">
    <Grid>
        <Border CornerRadius="17"
                BorderThickness="1"
                Margin="4">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16"
                                  ShadowDepth="3"
                                  Direction="270"
                                  Opacity="0.45"
                                  Color="#000000" />
            </Border.Effect>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B6D2E8F2" Offset="0" />
                    <GradientStop Color="#303C4650" Offset="0.48" />
                    <GradientStop Color="#8AA0B4BE" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#D33A4650" Offset="0" />
                    <GradientStop Color="#B3172028" Offset="0.42" />
                    <GradientStop Color="#E305090C" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border CornerRadius="15"
                Margin="8,8,8,58"
                IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#8FFFFFFF" Offset="0" />
                    <GradientStop Color="#18FFFFFF" Offset="0.55" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="12,8,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="98" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <cpu:GaugeControl Grid.Column="0"
                              Width="92"
                              Height="92"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Label="CPU"
                              Value="{Binding CpuUsage}" />

            <cpu:GaugeControl Grid.Column="1"
                              Width="68"
                              Height="68"
                              Margin="-3,18,0,0"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Label="RAM"
                              Value="{Binding MemoryUsage}" />
        </Grid>
    </Grid>
</UserControl>
