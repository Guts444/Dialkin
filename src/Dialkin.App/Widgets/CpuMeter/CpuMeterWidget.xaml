<UserControl x:Class="Dialkin.App.Widgets.CpuMeter.CpuMeterWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cpu="clr-namespace:Dialkin.App.Widgets.CpuMeter"
             Width="196"
             Height="152"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             AutomationProperties.Name="CPU and memory meter"
             AutomationProperties.HelpText="{Binding DebugTooltip}"
             ToolTip="{Binding DebugTooltip}">
    <Grid Background="Transparent">
        <Path Fill="#30000000"
              IsHitTestVisible="False"
              Panel.ZIndex="0">
            <Path.Data>
                <GeometryGroup FillRule="Nonzero">
                    <EllipseGeometry Center="65,83"
                                     RadiusX="54"
                                     RadiusY="51" />
                    <EllipseGeometry Center="139,50"
                                     RadiusX="39"
                                     RadiusY="36" />
                </GeometryGroup>
            </Path.Data>
            <Path.Effect>
                <BlurEffect Radius="2.75" />
            </Path.Effect>
        </Path>

        <cpu:GaugeControl Width="80"
                          Height="80"
                          Margin="96,4,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="RAM"
                          AutomationProperties.Name="Memory usage"
                          AutomationProperties.HelpText="{Binding MemoryUsage, StringFormat={}{0:0}%}"
                          Value="{Binding MemoryUsage}"
                          Panel.ZIndex="2" />

        <cpu:GaugeControl Width="112"
                          Height="112"
                          Margin="6,21,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Label="CPU"
                          AutomationProperties.Name="CPU usage"
                          AutomationProperties.HelpText="{Binding CpuUsage, StringFormat={}{0:0}%}"
                          Value="{Binding CpuUsage}"
                          Panel.ZIndex="3" />
    </Grid>
</UserControl>
